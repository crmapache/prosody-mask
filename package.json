{
  "name": "prosody-mask",
  "version": "0.1.0",
  "description": "Render a translucent intonation/breath-group mask over flowing text. Rules out of the box, or bring your own pitch points (LLM / pitch tracker).",
  "author": "Maksim Zolotoi",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "prosody",
    "intonation",
    "typography",
    "svg",
    "text",
    "speech",
    "melody"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "build:playground": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
